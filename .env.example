# CyberFate 环境变量配置示例
# 复制此文件为 .env.local 并填入真实的 API Key

# Anthropic API 配置（用于项目的 AI 功能）
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_BASE_URL=https://hk-api.gptbest.vip

# NextAuth 配置
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# 数据库
DATABASE_URL=postgresql://user:password@localhost:5432/cyberfate

# Stripe 支付配置
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# 说明：
# - ANTHROPIC_API_KEY: 用于八字分析、每日运势等 AI 功能
# - ANTHROPIC_BASE_URL: API 中转站地址（香港节点）
# - NEXTAUTH_SECRET: 生成方式 openssl rand -base64 32
# - STRIPE_SECRET_KEY: Stripe 后台获取
# - STRIPE_WEBHOOK_SECRET: Stripe Webhook 签名密钥
