// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_DATABASE_URL")
}

// 用户表
model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  emailVerified DateTime?
  passwordHash  String?
  
  // 微信登录
  wechatOpenId  String?   @unique
  wechatUnionId String?
  
  // 用户信息
  nickname      String?
  avatar        String?
  
  // 时间戳
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // 关联
  accounts      Account[]
  sessions      Session[]
  subscriptions Subscription[]
  orders        Order[]
  usageQuotas   UsageQuota[]
  
  @@map("users")
}

// NextAuth Account 表（OAuth 账号关联）
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([provider, providerAccountId])
  @@map("accounts")
}

// NextAuth Session 表
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("sessions")
}

// NextAuth 验证 Token
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  
  @@unique([identifier, token])
  @@map("verification_tokens")
}

// 订阅计划类型
enum SubscriptionPlan {
  monthly
  quarterly
  yearly
}

// 订阅状态
enum SubscriptionStatus {
  active
  expired
  cancelled
}

// 订阅表
model Subscription {
  id        String             @id @default(cuid())
  userId    String
  plan      SubscriptionPlan
  status    SubscriptionStatus @default(active)
  startAt   DateTime           @default(now())
  expireAt  DateTime
  autoRenew Boolean            @default(false)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("subscriptions")
}

// 支付方式
enum PayMethod {
  wechat
  alipay
}

// 订单状态
enum OrderStatus {
  pending
  paid
  failed
  refunded
}

// 订单表
model Order {
  id            String      @id @default(cuid())
  userId        String
  plan          SubscriptionPlan
  amount        Int         // 金额（分）
  payMethod     PayMethod?
  status        OrderStatus @default(pending)
  outTradeNo    String      @unique // 商户订单号
  transactionId String?     // 支付平台交易号
  paidAt        DateTime?
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("orders")
}

// 使用配额表（每日限制）
model UsageQuota {
  id          String   @id @default(cuid())
  userId      String
  date        String   // YYYY-MM-DD
  baziAiCount Int      @default(0) // 八字 AI 解读使用次数
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, date])
  @@map("usage_quotas")
}
